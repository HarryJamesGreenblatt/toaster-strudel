# toaster-strudel secrets template.
# PREFERRED: store secrets in Windows Credential Manager, not this file:
#   python -c "import keyring; keyring.set_password('toaster-strudel','ACOUSTID_CLIENT_KEY','YOUR_KEY')"
#   python -c "import keyring; keyring.set_password('toaster-strudel','DISCOGS_TOKEN','YOUR_TOKEN')"
#
# FALLBACK: copy this file to .env (which is gitignored) and fill in values.
# Never commit a real .env — it is ignored on purpose.

# AcoustID application API key (the `client` param) — acoustid.org/new-application
ACOUSTID_CLIENT_KEY=

# Discogs personal access token — discogs.com/settings/developers
DISCOGS_TOKEN=

# Descriptive User-Agent strings (required by Discogs & MusicBrainz; no key needed)
DISCOGS_USER_AGENT=toaster-strudel/0.1 (+https://github.com/HarryJamesGreenblatt/toaster-strudel)
MUSICBRAINZ_USER_AGENT=toaster-strudel/0.1 (+https://github.com/HarryJamesGreenblatt/toaster-strudel)
